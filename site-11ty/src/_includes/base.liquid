<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {%- if page.url == "/" -%}
    {%- assign pageTitle = site.name -%}
  {%- elsif title -%}
    {%- assign pageTitle = title | append: " — " | append: site.name -%}
  {%- else -%}
    {%- assign pageTitle = site.name -%}
  {%- endif -%}
  {%- assign explicitDesc = description | default: excerpt -%}
  {%- assign pageDesc = explicitDesc | seoDescription: content, site.description -%}
  {%- assign pageUrl = site.url | append: page.url -%}
  {%- if feature_image -%}
    {%- assign pageImage = site.url | append: feature_image -%}
  {%- else -%}
    {%- assign pageImage = site.url | append: "/images/2025/11/kalabhairava.png" -%}
  {%- endif -%}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}" />
  <link rel="canonical" href="{{ pageUrl }}" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.name }}" />
  {%- if layout == "post.liquid" -%}
  <meta property="og:type" content="article" />
  {%- else -%}
  <meta property="og:type" content="website" />
  {%- endif -%}
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDesc }}" />
  <meta property="og:url" content="{{ pageUrl }}" />
  <meta property="og:image" content="{{ pageImage }}" />
  {%- if date -%}
  <meta property="article:published_time" content="{{ date | isoDate }}" />
  <meta property="article:modified_time" content="{{ date | isoDate }}" />
  {%- endif -%}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDesc }}" />
  <meta name="twitter:image" content="{{ pageImage }}" />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ site.url }}/#organization",
        "name": {{ site.name | json }},
        "url": "{{ site.url }}",
        "description": {{ site.description | json }},
        "logo": "{{ site.url }}/images/2025/11/kalabhairava.png"
      },
      {
        "@type": "WebSite",
        "@id": "{{ site.url }}/#website",
        "name": {{ site.name | json }},
        "url": "{{ site.url }}",
        "description": {{ site.description | json }},
        "publisher": { "@id": "{{ site.url }}/#organization" }
      },
      {%- if layout == "post.liquid" %}
      {
        "@type": "BlogPosting",
        "@id": "{{ pageUrl }}#article",
        "headline": {{ title | json }},
        "description": {{ pageDesc | json }},
        "url": "{{ pageUrl }}",
        "mainEntityOfPage": "{{ pageUrl }}",
        "image": "{{ pageImage }}",
        "datePublished": "{{ date | isoDate }}",
        "dateModified": "{{ date | isoDate }}",
        "author": {
          "@type": "Person",
          "@id": "{{ site.url }}/about/#author",
          "name": "KaliPutra_AshishKapoor",
          "url": "{{ site.url }}/about/"
        },
        "publisher": { "@id": "{{ site.url }}/#organization" }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "{{ pageUrl }}#breadcrumb",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
          { "@type": "ListItem", "position": 2, "name": "Articles", "item": "{{ site.url }}/articles/" },
          { "@type": "ListItem", "position": 3, "name": {{ title | json }}, "item": "{{ pageUrl }}" }
        ]
      }
      {%- else %}
      {
        "@type": "WebPage",
        "@id": "{{ pageUrl }}#webpage",
        "name": {{ pageTitle | json }},
        "description": {{ pageDesc | json }},
        "url": "{{ pageUrl }}",
        "isPartOf": { "@id": "{{ site.url }}/#website" },
        "publisher": { "@id": "{{ site.url }}/#organization" }
      }
      {%- endif %}
    ]
  }
  </script>

  <link rel="icon" href="/images/2025/11/kalabhairava.png" type="image/png" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }}" href="/feed.xml" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <span class="logo-text">Inside The Triangles</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">Home</a>
        <a href="/poems/">Poems</a>
        <a href="/articles/">Articles</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>

  <main class="site-main">
    {{ content }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>© {{ "" | isoDate | truncate: 4, "" }} Inside The Triangles · KaliPutra_AshishKapoor</p>
      <p class="footer-tagline">Jai Ma Adya Mahakali · Jai Kalabhairava</p>
    </div>
  </footer>
</body>
</html>
