<article class="postcard">
  {%- if post.data.card_image or post.data.feature_image -%}
  <a href="{{ post.url }}" class="postcard-img-link">
    {%- if post.data.card_image -%}
      {%- assign imgSrc = post.data.card_image -%}
    {%- else -%}
      {%- assign imgSrc = post.data.feature_image -%}
    {%- endif -%}
    <img src="{{ imgSrc }}" alt="{{ post.data.title }}" class="postcard-img" loading="lazy" />
  </a>
  {%- endif -%}
  <div class="postcard-body">
    {%- if post.data.tags.size > 0 -%}
    <div class="postcard-tags">
      {%- for tag in post.data.tags -%}
      <span class="tag">{{ tag }}</span>
      {%- endfor -%}
    </div>
    {%- endif -%}
    <h3 class="postcard-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    {%- if post.data.excerpt -%}
    <p class="postcard-excerpt">{{ post.data.excerpt }}</p>
    {%- endif -%}
    <time class="postcard-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
  </div>
</article>