---
layout: "base.liquid"
---
<article class="post">
  <div class="post-container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/articles/">Articles</a>
      <span aria-hidden="true">/</span>
      <span>{{ title }}</span>
    </nav>

    <header class="post-header">
      {%- if feature_image -%}
      <div class="post-feature-image">
        <img src="{{ feature_image }}" alt="{{ title }}" class="post-feature-img" {{ feature_image | imageAttrs }} loading="eager" decoding="async" fetchpriority="high" />
      </div>
      {%- endif -%}

      {%- if tags.size > 0 -%}
      <div class="post-tags">
        {%- for tag in tags -%}
          {%- assign tagUrl = "" -%}
          {%- if tag == "Poems" -%}
            {%- assign tagUrl = "/poems/" -%}
          {%- elsif tag == "short articles" or tag == "long articles" or tag == "updates" -%}
            {%- assign tagUrl = "/articles/" -%}
          {%- endif -%}
          {%- if tagUrl != "" -%}
        <a href="{{ tagUrl }}" class="tag">{{ tag }}</a>
          {%- else -%}
        <span class="tag">{{ tag }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endif -%}

      <h1 class="post-title">{{ title }}</h1>

      {%- if excerpt -%}
      <p class="post-excerpt">{{ excerpt }}</p>
      {%- endif -%}

      <time class="post-date" datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
    </header>

    <div class="post-content">
      {{ content }}
    </div>

    <footer class="post-footer">
      <div class="post-navigation">
        <a href="/" class="back-link">← Back to all posts</a>
        <a href="/poems/" class="back-link">Browse poems →</a>
      </div>

      <section class="related-posts" aria-labelledby="related-posts-title">
        <h2 id="related-posts-title">More from Inside The Triangles</h2>
        <ul>
          {%- assign relatedCount = 0 -%}
          {%- for related in collections.allPosts -%}
            {%- if related.url != page.url and relatedCount < 3 -%}
              {%- assign relatedCount = relatedCount | plus: 1 -%}
          <li><a href="{{ related.url }}">{{ related.data.title }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </section>
    </footer>
  </div>
</article>
