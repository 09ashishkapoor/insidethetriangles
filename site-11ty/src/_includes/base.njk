<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {%- set pageTitle = title + " — " + site.name if title else site.name %}
  {%- set pageDesc = excerpt if excerpt else site.description %}
  {%- set pageUrl = site.url + page.url %}
  {%- set pageImage = (site.url + feature_image) if feature_image else (site.url + "/images/2025/11/kalabhairava.png") %}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDesc }}" />
  <link rel="canonical" href="{{ pageUrl }}" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:type" content="{{ 'article' if layout == 'post.njk' else 'website' }}" />
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDesc }}" />
  <meta property="og:url" content="{{ pageUrl }}" />
  <meta property="og:image" content="{{ pageImage }}" />
  {% if date %}<meta property="article:published_time" content="{{ date | isoDate }}" />{% endif %}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ pageTitle }}" />
  <meta name="twitter:description" content="{{ pageDesc }}" />
  <meta name="twitter:image" content="{{ pageImage }}" />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    {% if layout == "post.njk" %}
    "@type": "BlogPosting",
    "headline": {{ title | dump }},
    "description": {{ pageDesc | dump }},
    "url": "{{ pageUrl }}",
    "image": "{{ pageImage }}",
    "datePublished": "{{ date | isoDate }}",
    "author": { "@type": "Person", "name": "KaliPutra_AshishKapoor" },
    "publisher": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
    {% else %}
    "@type": "WebSite",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "description": "{{ site.description }}"
    {% endif %}
  }
  </script>

  <link rel="icon" href="/images/2025/11/kalabhairava.png" type="image/png" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="alternate" type="application/rss+xml" title="{{ site.name }}" href="/feed.xml" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <span class="logo-text">Inside The Triangles</span>
      </a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/poems/">Poems</a>
        <a href="/articles/">Articles</a>
        <a href="/about/">About</a>
      </nav>
    </div>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>© {{ "" | isoDate | truncate(4, false, "") }} Inside The Triangles · KaliPutra_AshishKapoor</p>
      <p class="footer-tagline">Jai Ma Adya Mahakali · Jai Kalabhairava</p>
    </div>
  </footer>
</body>
</html>
