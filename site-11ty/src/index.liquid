---
layout: "base.liquid"
title: "Home"
description: "Devotional poems, stories, and spiritual reflections on Ma Adya Mahakali, Kali, Bhairava, and sacred creativity by Ashish Kapoor."
---
<section class="hero">
  <div class="hero-inner">
    {%- assign heroImage = "/images/2025/06/boo2.jpg" -%}
    <img src="{{ heroImage }}" alt="Inside The Triangles devotional artwork" class="hero-logo" {{ heroImage | imageAttrs }} loading="eager" decoding="async" fetchpriority="high" />
    <h1 class="hero-title">Inside The Triangles</h1>
    <p class="hero-sub">Devotional poems, stories, and reflections about Ma Adya Mahakali, Kali, Bhairava, and sacred creativity.</p>
  </div>
</section>

<section class="post-grid-section">
  <div class="section-inner">
    <h2 class="section-title">Latest</h2>
    <div class="post-grid">
      {%- for post in collections.allPosts limit: 12 -%}
        {%- include "postcard.liquid" -%}
      {%- endfor -%}
    </div>
    {%- if collections.allPosts.size > 12 -%}
    <div class="see-all">
      <a href="/articles/" class="btn-outline">See all posts</a>
    </div>
    {%- endif -%}
  </div>
</section>

<section class="category-strips">
  <div class="section-inner">
    <div class="category-strip">
      <h2 class="section-title">Poems</h2>
      <div class="post-grid">
        {%- for post in collections.poems limit: 6 -%}
          {%- include "postcard.liquid" -%}
        {%- endfor -%}
      </div>
      <div class="see-all"><a href="/poems/" class="btn-outline">All poems →</a></div>
    </div>
  </div>
</section>